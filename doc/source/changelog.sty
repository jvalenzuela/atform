% This file contains the release history listing presented before the ToC.
\renewcommand{\sphinxtableofcontentshook}{
  \chapter*{Release History}
  \begin{description}

  \item[0.1] Initial proof of concept.

  \item[0.2] Add configurable output section folder depth, and support
    Python v3.12 and v3.13.

  \item[1.0]
    \begin{itemize}
      \item Minor PDF format improvements.
      \item Change test definition from Test() class to add\_test() function.
      \item Make procedure step labels local, removing the
        need for globally unique step labels.
      \item Make most optional API arguments keyword-only.
      \item Build PDFs in parallel to improve generation time.
      \item Minor API documentation clarifications.
      \item Add support for procedure step images.
      \item Add support for PNG images.
      \item Add CLI option to select PDFs to build.
      \item Implement ID locking system to prevent inadverent numbering shifts.
      \item Add list\_tests().
      \item Remove Python 3.7 and 3.8 support.
      \item Require conventional \_\_name\_\_ == ``\_\_main\_\_'' guard
        around generate().
      \item Add build GUI.
    \end{itemize}

  \item[2.0]
    \begin{itemize}
      \item Fix GUI bug when simultaneously selecting tests and sections.
      \item Remove Python 3.9 support due to end-of-life.
      \item Add Python 3.14 support.
      \item Add build information in bottom-left corner of PDF output.
      \item Correct user manual API cross-reference errors.
      \item Improve GUI preview to depict actual PDF output.
      \item Add embedded notices.
      \item Automatically scale images.
      \item Remove set\_id\_depth function and enhance section function
        to permit variable-depth sectioning.
    \end{itemize}

  \item[3.0] Add terms functionality.

  \item[4.0] Add get\_terms() API function.
  \end{description}
}
